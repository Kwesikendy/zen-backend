{
  "name": "zenran-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "npm run build && npx prisma db push --accept-data-loss && node dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "lint": "eslint . --ext .ts",
    "test": "jest --coverage --runInBand"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/multer": "^2.0.0",
    "argon2": "^0.30.0",
    "axios": "^1.13.2",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "firebase-admin": "13.8.0",
    "helmet": "^6.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "pino": "^8.0.0",
    "socket.io": "^4.8.1",
    "ws": "^8.13.0",
    "zod": "^3.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "dotenv": "^16.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ngrok": "^5.0.0-beta.2",
    "prisma": "^5.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
