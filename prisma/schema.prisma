generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  restaurants Restaurant[]
  refreshTokens RefreshToken[]
  orders    Order[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Restaurant {
  id        String   @id @default(uuid())
  owner     User?    @relation(fields: [ownerId], references: [id])
  ownerId   String?
  name      String
  address   String
  phone     String?
  menus     Menu[]
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Menu {
  id          String     @id @default(uuid())
  restaurant  Restaurant @relation(fields:[restaurantId], references:[id])
  restaurantId String
  title       String
  items       MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MenuItem {
  id        String  @id @default(uuid())
  menu      Menu    @relation(fields:[menuId], references:[id])
  menuId    String
  name      String
  price     Float
  qty       Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id           String      @id @default(uuid())
  userId       String?
  restaurantId String
  total        Float
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  customerName String?
  tableNumber  String?

  user       User?       @relation(fields: [userId], references: [id])
  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  order     Order   @relation(fields:[orderId], references:[id])
  orderId   String
  name      String
  price     Float
  qty       Int
}

enum Role {
  USER
  ADMIN
  OWNER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}
