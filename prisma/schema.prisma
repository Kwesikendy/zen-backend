generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  password      String
  role          Role           @default(USER)
  isBanned      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pushToken     String?
  orders          Order[]
  refreshTokens   RefreshToken[]
  restaurants     Restaurant[]
  payouts         VendorPayout[]
  adminActions    AdminAction[]
  courierProfile  CourierProfile?
  sentDeliveries  Delivery[]       @relation("sender")
  courierDeliveries Delivery[]     @relation("courier")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Restaurant {
  id        String   @id @default(uuid())
  ownerId   String?
  name      String
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  phone     String?
  latitude  Float?   @default(5.6037)  // Default: Accra, Ghana
  longitude Float?   @default(-0.1870)
  menus     Menu[]
  orders    Order[]
  owner     User?    @relation(fields: [ownerId], references: [id])
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  rejectionReason String?
  isVisible       Boolean   @default(true) // Admin toggle for visibility

  @@index([ownerId])
}

model Menu {
  id           String     @id @default(uuid())
  restaurantId String
  title        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  items        MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id          String           @id @default(uuid())
  menuId      String
  name        String
  price       Decimal          @db.Decimal(10, 2)
  qty         Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  description String?
  imageUrl    String?
  menu        Menu             @relation(fields: [menuId], references: [id])
  options     MenuItemOption[]
  orderItems  OrderItem[]
  reviews     Review[]

  @@index([menuId])
}

model Review {
  id         String   @id @default(uuid())
  menuItemId String
  userId     String?
  userName   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([menuItemId])
}

model MenuItemOption {
  id         String   @id @default(uuid())
  menuItemId String
  name       String
  price      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model Order {
  id                String        @id @default(uuid())
  userId            String?
  restaurantId      String
  total             Decimal       @db.Decimal(10, 2)
  status            OrderStatus   @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  customerName      String?
  tableNumber       String?
  paymentMethod     PaymentMethod @default(CASH)
  paymentStatus     PaymentStatus @default(PENDING)
  paystackReference String?
  phoneNumber       String?
  ticketCode        String?
  // Delivery Location Fields
  deliveryAddress   String?
  deliveryLat       Float?
  deliveryLng       Float?
  
  restaurant        Restaurant     @relation(fields: [restaurantId], references: [id])
  user              User?          @relation(fields: [userId], references: [id])
  items             OrderItem[]
  transactions      Transaction[]
  vendorPayouts     VendorPayout[]

  @@index([restaurantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([restaurantId, status]) // Composite index for dashboard filtering
  @@index([paystackReference])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  price           Decimal  @db.Decimal(10, 2)
  qty             Int
  menuItemId      String
  selectedOptions Json?
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])
  order           Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

enum Role {
  USER
  ADMIN
  OWNER
  COURIER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOMO
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model Transaction {
  id               String             @id @default(uuid())
  orderId          String
  order            Order              @relation(fields: [orderId], references: [id])
  type             TransactionType
  method           PaymentMethod
  amount           Decimal            @db.Decimal(10, 2)
  status           TransactionStatus
  paystackRef      String?
  settlementStatus SettlementStatus?
  settledAt        DateTime?
  metadata         Json?
  createdAt        DateTime           @default(now())

  @@index([orderId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model VendorPayout {
  id        String       @id @default(uuid())
  vendorId  String
  vendor    User         @relation(fields: [vendorId], references: [id])
  amount    Decimal      @db.Decimal(10, 2)
  status    PayoutStatus
  orderId   String?
  order     Order?       @relation(fields: [orderId], references: [id])
  paidAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([vendorId])
  @@index([status])
}

model AdminAction {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
}

enum TransactionType {
  PAYMENT
  PAYOUT
  REFUND
  COMMISSION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum SettlementStatus {
  PENDING
  SETTLED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

// ─── Delivery Feature ───────────────────────────────────────

model CourierProfile {
  id            String        @id @default(uuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id])
  vehicleType   VehicleType   @default(MOTORBIKE)
  licensePlate  String?
  isOnline      Boolean       @default(false)
  isApproved    Boolean       @default(false)
  currentLat    Float?
  currentLng    Float?
  rating        Float         @default(5.0)
  totalDeliveries Int         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([isOnline, isApproved])
}

model Delivery {
  id              String           @id @default(uuid())
  senderId        String
  sender          User             @relation("sender", fields: [senderId], references: [id])
  courierId       String?
  courier         User?            @relation("courier", fields: [courierId], references: [id])
  
  // Package Info
  packageDesc     String
  packagePhoto    String?
  
  // Pickup
  pickupAddress   String
  pickupLat       Float
  pickupLng       Float
  pickupPhone     String
  
  // Dropoff
  dropoffAddress  String
  dropoffLat      Float
  dropoffLng      Float
  receiverName    String
  receiverPhone   String
  
  // Pricing & Payment
  distanceKm      Float
  price           Decimal          @db.Decimal(10, 2)
  paymentMethod   PaymentMethod    @default(CASH)
  paymentStatus   PaymentStatus    @default(PENDING)
  paystackRef     String?
  
  // Status & Scheduling
  status          DeliveryStatus   @default(REQUESTED)
  scheduledAt     DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  cancelReason    String?
  
  // Tracking
  trackingCode    String           @unique
  
  // Rating
  rating          Int?
  ratingComment   String?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  trackingPoints  DeliveryTracking[]

  @@index([senderId])
  @@index([courierId])
  @@index([status])
  @@index([trackingCode])
  @@index([createdAt])
}

model DeliveryTracking {
  id          String   @id @default(uuid())
  deliveryId  String
  delivery    Delivery @relation(fields: [deliveryId], references: [id])
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())

  @@index([deliveryId])
  @@index([createdAt])
}

enum DeliveryStatus {
  REQUESTED
  ACCEPTED
  ARRIVED_PICKUP
  PICKED_UP
  IN_TRANSIT
  ARRIVED_DROPOFF
  DELIVERED
  COMPLETED
  CANCELLED
}

enum VehicleType {
  MOTORBIKE
  CAR
  BICYCLE
}
